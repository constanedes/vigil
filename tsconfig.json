{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": [
        "./core/src/*"
      ],
      "@scraper/*": [
        "./scraper/src/*"
      ]
    },
    "types": [
      "bun"
    ]
  }
}